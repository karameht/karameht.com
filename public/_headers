/*
  Content-Security-Policy: default-src 'self'; img-src 'self' data: https:; script-src 'self' 'unsafe-inline' https://observe.karameht.com; style-src 'self' 'unsafe-inline'; font-src 'self' https: data:; connect-src 'self' https://observe.karameht.com; object-src 'none'; frame-ancestors 'none'
