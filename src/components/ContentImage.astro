---
export interface Props {
  src: string;
  alt: string;
  width?: string | number;
  loading?: "lazy" | "eager";
  srcset?: string;
  sizes?: string;
}
const { src, alt, width = "100%", loading = "lazy", srcset, sizes } = Astro.props as Props;
---

<img
  src={src}
  alt={alt}
  width={width}
  loading={loading}
  srcset={srcset}
  sizes={sizes}
  style="max-width: 100%; height: auto;"
/>
