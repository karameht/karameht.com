---
import Aside from "@/components/Aside.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import "@/styles/karameht.css";

interface LayoutProps {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
  noIndex?: boolean;
  structuredData?: boolean;
}
const {
  title = "karameht | Manufaktur für digitale Askese",
  description = "Das Siegel der Unnachahmlichkeit in der Manufaktur für digitale Askese ... die Schöpfung von [ˈʁɛflɛksi̯oːn]",
  image = "https://karameht.com/og-image.png",
  url = "https://karameht.com/",
  noIndex = false,
  structuredData = true,
} = Astro.props as LayoutProps;
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: title,
  url,
  isPartOf: {
    "@type": "WebSite",
    name: "karameht",
    url: "https://karameht.com/",
  },
  primaryImageOfPage: image,
  description,
};
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "karameht",
  url: "https://karameht.com/",
  logo: {
    "@type": "ImageObject",
    url: image,
  },
  sameAs: ["https://www.npmjs.com/~karameht", "https://github.com/karameht"],
};
const siteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "karameht",
  url: "https://karameht.com/",
};
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Mehmet Karaca",
  url: "https://karameht.com/",
  image,
  sameAs: ["https://www.npmjs.com/~karameht", "https://github.com/karameht"],
};
---

<html lang="de" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>

    <!-- SEO Meta Tags -->
    <meta name="description" content={description} />
    <meta name="robots" content={noIndex ? "noindex, nofollow" : "index, follow"} />
    <meta name="author" content="Mehmet Karaca" />
    <meta name="theme-color" content="#111111" media="(prefers-color-scheme: dark)" />

    <!-- Open Graph (Facebook, LinkedIn, WhatsApp) -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="karameht" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="1080" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content={description} />

    <!-- Canonical URL -->
    <link rel="canonical" href={url} />

    <!-- Structured Data -->
    {
      structuredData && (
        <>
          <script is:inline type="application/ld+json" set:html={JSON.stringify(siteSchema)} />
          <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
          <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
          <script is:inline type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
        </>
      )
    }

    <!-- Matomo Analytics - observe the sytsem -->
    <script>
      var _paq = (window._paq = window._paq || []);
      _paq.push(["setDoNotTrack", true]);
      _paq.push(["disableCookies"]);
      _paq.push(["trackPageView"]);
      _paq.push(["enableLinkTracking"]);
      (function () {
        var u = "//observe.karameht.com/";
        _paq.push(["setTrackerUrl", u + "matomo.php"]);
        _paq.push(["setSiteId", "1"]);
        var d = document,
          g = d.createElement("script"),
          s = d.getElementsByTagName("script")[0];
        g.async = true;
        g.src = u + "matomo.js";
        s.parentNode?.insertBefore(g, s);
      })();
    </script>
  </head>
  <body class="grid">
    <Header />
    <Aside />
    <main class="main">
      <section class="main__section">
        <slot />
      </section>
    </main>
    <Footer />
    <script src="/src/scripts/karameht.ts"></script>
  </body>
</html>
